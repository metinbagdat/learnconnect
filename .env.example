# LearnConnect Environment Variables
# Copy this file to .env and fill in your actual values
# Never commit the .env file to version control

# ============================================
# Required Variables (Production)
# ============================================

# Database Connection
# Neon PostgreSQL connection string
DATABASE_URL=postgresql://user:password@host/database?sslmode=require

# Session Security
# Generate with: openssl rand -base64 32
SESSION_SECRET=your-session-secret-key-here

# ============================================
# Optional Variables
# ============================================

# Node Environment
# Options: development, production, test
NODE_ENV=development

# ============================================
# AI Services (Optional)
# ============================================

# OpenAI API Key
# Get from: https://platform.openai.com/api-keys
OPENAI_API_KEY=

# Anthropic API Key
# Get from: https://console.anthropic.com/settings/keys
ANTHROPIC_API_KEY=

# ============================================
# Payment Processing (Optional)
# ============================================

# Stripe Secret Key
# Get from: https://dashboard.stripe.com/apikeys
STRIPE_SECRET_KEY=

# Stripe Publishable Key (for frontend)
# Get from: https://dashboard.stripe.com/apikeys
STRIPE_PUBLISHABLE_KEY=

# Stripe Webhook Secret
# Get from: Stripe Dashboard -> Developers -> Webhooks
STRIPE_WEBHOOK_SECRET=

# Stripe Price ID
STRIPE_PRICE_ID=

# PayPal Client ID
# Get from: https://developer.paypal.com/dashboard/applications/sandbox
PAYPAL_CLIENT_ID=

# PayPal Client Secret
# Get from: https://developer.paypal.com/dashboard/applications/sandbox
PAYPAL_CLIENT_SECRET=

# ============================================
# Application Settings (Optional)
# ============================================

# Site URL (for sitemap generation)
SITE_URL=https://learnconnect.net

# Webhook Secret (for custom webhooks)
WEBHOOK_SECRET=

# Enable Debug Mode
# Options: true, false
ENABLE_DEBUG=false

# ============================================
# Advanced AI Integrations (Optional)
# ============================================

# AI Integrations - OpenAI
AI_INTEGRATIONS_OPENAI_API_KEY=
AI_INTEGRATIONS_OPENAI_BASE_URL=

# AI Integrations - Anthropic
AI_INTEGRATIONS_ANTHROPIC_API_KEY=
AI_INTEGRATIONS_ANTHROPIC_BASE_URL=

# AI Integrations - OpenRouter
AI_INTEGRATIONS_OPENROUTER_API_KEY=
AI_INTEGRATIONS_OPENROUTER_BASE_URL=https://openrouter.ai/api/v1

# ============================================
# Notification Services (Optional)
# ============================================

# Reminder Webhook URL
REMINDER_WEBHOOK_URL=

# ============================================
# Replit Deployment (Optional)
# ============================================

# Replit deployment ID (only for Replit deployments)
REPL_ID=